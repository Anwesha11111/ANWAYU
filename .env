# ─── Runtime Environment ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ─── PostgreSQL (Primary Relational Store) ───────────────────────────────────
DATABASE_URL=postgresql://gramgyan_user:strongpassword@localhost:5432/gramgyan_db
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ─── Redis (Cache + Bull Queue) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_256BIT_RANDOM_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_256BIT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ─── Nebius Token Factory — OpenAI-Compatible Inference ─────────────────────
# SDK: openai (base_url override) — https://api.tokenfactory.nebius.com/v1/
NEBIUS_API_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_API_KEY=REPLACE_WITH_NEBIUS_API_KEY

# ── Model Routing Identifiers (Nebius-hosted) ─────────────────────────────
# Standard Dialogue / AI Mentor  (~90 Tok/s)
MODEL_STANDARD_DIALOGUE=nvidia/Nemotron-3-Nano-Omni

# Project Guidance / Multi-Agent (~59 Tok/s)
MODEL_PROJECT_GUIDANCE=nvidia/Nemotron-3-Ultra-550b-a55b

# Advanced STEM / Code Reasoning (~85 Tok/s) — supports <think> blocks
MODEL_STEM_REASONING=Qwen/Qwen3-Next-80B-A3B

# Image / Homework OCR (~20 Tok/s) — vision-language multimodal
MODEL_VISION_OCR=Qwen/Qwen2.5-VL-72B-Instruct

# Scam Detection Worker (~70 Tok/s) — background async
MODEL_SCAM_DETECTION=Qwen/Qwen3-30B-A3B-Instruct-2507

# ─── Security / KYB ──────────────────────────────────────────────────────────
GSTIN_VALIDATION_API=https://api.example.com/gstin
GSTIN_VALIDATION_KEY=REPLACE_WITH_KEY
DOMAIN_BLOCKLIST=gmail.com,yahoo.com,hotmail.com,outlook.com,protonmail.com,yopmail.com,mailinator.com

# ─── Crypto / Anti-Gaming ────────────────────────────────────────────────────
COMPETENCY_HASH_SECRET=REPLACE_WITH_HASH_SECRET
MIN_SUBMISSION_SPEED_MS=4000
MAX_TAB_SWITCH_THRESHOLD=5

# ─── Cloud Run / GCP ─────────────────────────────────────────────────────────
GCP_PROJECT_ID=gramgyan-production
GCP_REGION=asia-south1
CLOUD_RUN_SERVICE=gramgyan-backend
GCP_SERVICE_ACCOUNT=gramgyan-sa@gramgyan-production.iam.gserviceaccount.com

# ─── Health Check Thresholds ─────────────────────────────────────────────────
HEALTH_MEMORY_THRESHOLD_MB=512
HEALTH_CPU_THRESHOLD_PERCENT=85
HEALTH_LATENCY_THRESHOLD_MS=200

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty