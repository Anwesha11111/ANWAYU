{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.test.ts"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/server.ts",
    "!src/db/**"
  ],
  "coverageThreshold": {
    "global": { "lines": 60 }
  },
  "setupFiles": ["<rootDir>/src/__tests__/setup.ts"]
}
